@model CokluKullaniciCRMSistemi.Models.Entity.Incomes
@{
    ViewBag.Title = "Yeni Gelir Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-4xl mx-auto p-8">
    <div class="flex flex-wrap justify-between gap-3 mb-8">
        <div class="flex flex-col gap-2">
            <p class="text-[#111418] dark:text-white text-3xl font-bold tracking-tight">Yeni Gelir Ekle</p>
            <p class="text-[#617589] dark:text-gray-400 text-base font-normal leading-normal">
                Aşağıya yeni gelir girişinin ayrıntılarını girin.
            </p>
        </div>
        <button onclick="window.location.href='/Gelir/Index'"
                class="flex items-center justify-center gap-2 px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors">
            <span class="material-symbols-outlined">arrow_back</span>
            <span>Geri Dön</span>
        </button>
    </div>

    <div class="bg-white dark:bg-[#192734] rounded-xl shadow-sm p-8">
        @using (Html.BeginForm("YeniGelirEkle", "Gelir", FormMethod.Post, new { @class = "space-y-6" }))
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary(true, "", new { @class = "text-red-500 text-sm mb-4" })

            <div class="flex flex-col">
                <label class="text-[#111418] dark:text-white text-sm font-medium leading-normal pb-2" for="Source">Kaynak</label>
                <div class="relative">
                    @Html.TextBoxFor(m => m.Source, new
                    {
                        @class = "form-input w-full rounded-lg text-[#111418] dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-[#dbe0e6] dark:border-gray-600 bg-white dark:bg-background-dark h-12 placeholder:text-[#617589] dark:placeholder:text-gray-500 px-4 text-base",
                        placeholder = "örn. Proje Alfa, Aylık Ücret"
                    })
                </div>
                @Html.ValidationMessageFor(m => m.Source, "", new { @class = "text-red-500 text-sm mt-1" })
            </div>

            <div class="flex flex-col">
                <label class="text-[#111418] dark:text-white text-sm font-medium leading-normal pb-2" for="Amount">Miktar</label>
                <div class="relative">
                    @Html.TextBoxFor(m => m.Amount, new
                    {
                        @class = "form-input w-full rounded-lg text-[#111418] dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-[#dbe0e6] dark:border-gray-600 bg-white dark:bg-background-dark h-12 placeholder:text-[#617589] dark:placeholder:text-gray-500 px-4 text-base",
                        placeholder = "1500.00",
                        type = "number",
                        step = "0.01"
                    })
                </div>
                @Html.ValidationMessageFor(m => m.Amount, "", new { @class = "text-red-500 text-sm mt-1" })
            </div>

            <div class="border-t border-gray-200 dark:border-gray-700 pt-6 flex justify-end gap-3">
                <button type="submit"
                        class="flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors font-medium">
                    <span class="material-symbols-outlined">save</span>
                    <span>Kaydet</span>
                </button>
            </div>
        }
    </div>
</div>
