
@model IEnumerable<CokluKullaniciCRMSistemi.Models.Entity.Incomes>

@{
    ViewBag.Title = "Gelirler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-between items-center mb-6">
    <p class="text-[#101418] dark:text-white text-4xl font-black leading-tight">Gelirler</p>
    <a href="/Gelir/YeniGelirEkle">
        <button class="flex items-center justify-center rounded-lg h-12 px-5 bg-primary text-white font-bold hover:bg-primary/90">
            <span class="material-symbols-outlined mr-2">add</span>
            Yeni Ekle
        </button>
    </a>
</div>

<div class="flex overflow-hidden rounded-xl border border-[#dae0e7] dark:border-[#2c3a47] bg-white dark:bg-[#1a2632]">
    <table class="flex-1">
        <thead>
            <tr>
                <th class="px-4 py-3 text-left text-sm font-medium">Kullanıcı ID</th>
                <th class="px-4 py-3 text-left text-sm font-medium">Kaynak</th>
                <th class="px-4 py-3 text-left text-sm font-medium">Tutar</th>
                <th class="px-4 py-3 text-left text-sm font-medium">Tarih</th>
                <th class="px-4 py-3 text-left text-sm font-medium">İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="border-t">
                    <td class="px-4 py-2">@item.UserId</td>
                    <td class="px-4 py-2">@item.Source</td>
                    <td class="px-4 py-2">₺@item.Amount</td>
                    <td class="px-4 py-2">@item.Date.ToString("yyyy-MM-dd")</td>
                    <td class="px-4 py-2">
                        <a href="@Url.Action("Duzenle", "Gelir", new { id = item.IncomeId })" class="text-primary hover:text-primary/80">
                            <span class="material-symbols-outlined text-base">edit</span>
                        </a>
                        <a href="@Url.Action("Sil", "Gelir", new { id = item.IncomeId })"
                           onclick="return confirm('Bu geliri silmek istediğinize emin misiniz?');"
                           class="text-red-600 hover:text-red-800 ml-2">
                            <span class="material-symbols-outlined text-base">delete</span>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


