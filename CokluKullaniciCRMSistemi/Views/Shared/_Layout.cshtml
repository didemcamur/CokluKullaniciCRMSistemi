<!DOCTYPE html>
<html class="light" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Kurumsal CRM</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#007fff",
                        "background-light": "#f5f7f8",
                        "background-dark": "#0f1923",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                },
            },
        }
    </script>

    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-[#101418] dark:text-white">
    <div class="flex min-h-screen">

        <!-- ✅ SIDEBAR (sabit) -->
        <aside class="flex flex-col gap-y-6 p-4 bg-white dark:bg-[#1a2632] w-64 border-r border-[#dae0e7] dark:border-[#2c3a47]">
            <div class="flex items-center gap-3 px-3">
                <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10"
                     style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuAONkb36-FnRCtl7UsYF5geJUF-iRULcty0A-AcnBk9RmaXZcczTH0pwTfm7WsbJfQ3yjb5VPqhZNroWnCTzBRpt8bXmeaRbsO7aBAR5W83mWbOwLpx_sUkRZmldikT1yPHO3EYD47HBvccrIc7sRCmeSBH_web6H-T4frmpRUwnjgxEMQE1Rl2WfRZGGija3dYZ3b4bleoltK707u12C-WMmF1wk4knA6RHgSMD_yvPfSFF0HUs2sQKWM9Q02bY2uA8-alIbhOwSkh");'></div>
                <div class="flex flex-col">
                    <h1 class="text-[#101418] dark:text-white text-base font-bold">Kurumsal CRM</h1>
                    <p class="text-[#5e758d] dark:text-[#a0b3c6] text-sm">KOBİ Çözümleri</p>
                </div>
            </div>

            <nav class="flex flex-col gap-2">
                <a href="/Admin/Index" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-primary/10 dark:hover:bg-primary/20">
                    <span class="material-symbols-outlined">dashboard</span>
                    <p>Dashboard</p>
                </a>
                <a href="/Gorevler/Index" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-primary/10 dark:hover:bg-primary/20">
                    <span class="material-symbols-outlined">task_alt</span>
                    <p>Görevler</p>
                </a>
                <a href="/Gelir/Index" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-primary/10 dark:hover:bg-primary/20">
                    <span class="material-symbols-outlined">payments</span>
                    <p>Gelirler</p>
                </a>
                <a href="/Gider/Index" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-primary/10 dark:hover:bg-primary/20">
                    <span class="material-symbols-outlined">receipt_long</span>
                    <p>Giderler</p>
                </a>
                <a href="/Notlar/Index" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-primary/10 dark:hover:bg-primary/20">
                    <span class="material-symbols-outlined">payments</span>
                    <p>Notlar</p>
                </a>
                <a href="/Kullanici/Cikis">
                    <button class="flex w-full cursor-pointer items-center justify-center gap-2 rounded-lg h-10 px-4 bg-gray-100 dark:bg-gray-800 text-text-light dark:text-text-dark hover:bg-gray-200 dark:hover:bg-gray-700 text-sm font-medium">
                        <span class="material-symbols-outlined">logout</span>
                        <span class="truncate">Çıkış Yap</span>
                    </button>

                </a>
            </nav>
        </aside>

        <!-- ✅ SAYFA İÇERİĞİ (değişen kısım) -->
        <main class="flex-1 p-6">
            @RenderBody()
        </main>
    </div>
</body>
</html>
