@model CokluKullaniciCRMSistemi.Models.Entity.Users
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yeni Kullanıcı Ekle</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center p-4">
    <div class="bg-white shadow-lg rounded-xl w-full max-w-lg p-8">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Yeni Kullanıcı Ekle</h1>

        <form action="/Admin/AddUser" method="post" class="space-y-5">
            <div>
                @Html.LabelFor(m => m.FullName, "Ad - Soyad", new { @class = "block text-sm font-medium text-gray-700 mb-1" })
                @Html.TextBoxFor(m => m.FullName, new { @class = "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 bg-gray-50 text-gray-900" })
                @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-red-500 text-sm" })
            </div>

            <div>
                @Html.LabelFor(m => m.Username,"Kullanıcı Adı", new { @class = "block text-sm font-medium text-gray-700 mb-1" })
                @Html.TextBoxFor(m => m.Username, new { @class = "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 bg-gray-50 text-gray-900" })
                @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-red-500 text-sm" })
            </div>

            <div>
                @Html.Label("Şifre", new { @class = "block text-sm font-medium text-gray-700 mb-1" })
                @Html.PasswordFor(m => m.PasswordHash, new { @class = "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 bg-gray-50 text-gray-900" })
                @Html.ValidationMessageFor(m => m.PasswordHash, "", new { @class = "text-red-500 text-sm" })
            </div>

            <div>
                @Html.LabelFor(m => m.Email,"E-Mail", new { @class = "block text-sm font-medium text-gray-700 mb-1" })
                @Html.TextBoxFor(m => m.Email, new { @class = "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 bg-gray-50 text-gray-900" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-red-500 text-sm" })
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Rol</label>
                <select name="IsOwner" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none bg-gray-50 text-gray-900">
                    <option value="false">Kullanıcı</option>
                    <option value="true">Yönetici</option>
                </select>
            </div>

            <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition-all">
                Kaydet
            </button>
        </form>
    </div>
</body>
</html>
