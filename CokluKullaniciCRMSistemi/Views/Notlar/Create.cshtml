@model CokluKullaniciCRMSistemi.Models.Entity.Notes

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Yeni Not Ekle";
}

<!-- Page Heading -->
<div class="flex flex-wrap justify-between items-center gap-4 mb-6">
    <div>
        <h1 class="text-3xl font-bold text-text-light dark:text-text-dark">Yeni Not Ekle</h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">Yeni bir not oluşturun</p>
    </div>
    <button onclick="window.location.href='/Notlar/Index'"
            class="flex items-center justify-center rounded-lg h-10 px-5 bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-200 text-sm font-medium hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors">
        <span class="material-symbols-outlined mr-2">arrow_back</span>
        <span class="truncate">Geri Dön</span>
    </button>
</div>

<!-- Form Card -->
<div class="max-w-3xl mx-auto">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="p-6 bg-gradient-to-r from-blue-500 to-purple-600">
            <div class="flex items-center gap-3 text-white">
                <span class="material-symbols-outlined text-4xl">note_add</span>
                <div>
                    <h2 class="text-xl font-bold">Not Bilgileri</h2>
                    <p class="text-sm opacity-90">Lütfen not detaylarını doldurun</p>
                </div>
            </div>
        </div>

        <form method="post" action="/Notlar/Create" class="p-6">
            <div class="space-y-6">
                <!-- Başlık -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        <span class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-lg">title</span>
                            Not Başlığı
                            <span class="text-red-500">*</span>
                        </span>
                    </label>
                    <input type="text" name="Title" required
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent bg-white dark:bg-gray-700 text-text-light dark:text-text-dark"
                           placeholder="Örn: Proje Toplantı Notları" />
                </div>

                <!-- Kullanıcı -->
                <!--<div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        <span class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-lg">person</span>
                            Kullanıcı
                            <span class="text-red-500">*</span>
                        </span>
                    </label>
                    <select name="UserId" required
                            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent bg-white dark:bg-gray-700 text-text-light dark:text-text-dark">
                        <option value="">Kullanıcı Seçin</option>
                        @foreach (var user in ViewBag.Users)
                        {
                            <option value="@user.UserId">@user.FullName</option>
                        }
                    </select>
                </div>-->

                <!-- Görev (Opsiyonel) -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        <span class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-lg">task_alt</span>
                            Bağlı Görev (Opsiyonel)
                        </span>
                    </label>
                    <select name="TaskId"
                            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent bg-white dark:bg-gray-700 text-text-light dark:text-text-dark">
                        <option value="">Görev Seçin (İsteğe Bağlı)</option>
                        @foreach (var task in ViewBag.Tasks)
                        {
                            <option value="@task.TaskId">@task.Title</option>
                        }
                    </select>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Bu not bir göreve bağlanabilir (zorunlu değil)</p>
                </div>

                <!-- İçerik -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        <span class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-lg">description</span>
                            Not İçeriği
                            <span class="text-red-500">*</span>
                        </span>
                    </label>
                    <textarea name="Content" required rows="8"
                              class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent bg-white dark:bg-gray-700 text-text-light dark:text-text-dark resize-none"
                              placeholder="Not içeriğini buraya yazın..."></textarea>
                    <div class="mt-2 flex items-center justify-between">
                        <p class="text-xs text-gray-500 dark:text-gray-400">Detaylı not bilgilerini ekleyin</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400" id="charCount">0 karakter</p>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex items-center gap-4 pt-4">
                    <button type="submit"
                            class="flex-1 flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors font-medium shadow-sm">
                        <span class="material-symbols-outlined">save</span>
                        <span>Not Kaydet</span>
                    </button>
                    <button type="button" onclick="window.location.href='/Notlar/Index'"
                            class="flex-1 flex items-center justify-center gap-2 px-6 py-3 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors font-medium">
                        <span class="material-symbols-outlined">cancel</span>
                        <span>İptal</span>
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Tips Card -->
    <div class="mt-6 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
        <div class="flex gap-3">
            <span class="material-symbols-outlined text-blue-600 dark:text-blue-400">lightbulb</span>
            <div>
                <h3 class="font-medium text-blue-900 dark:text-blue-300 mb-1">İpuçları</h3>
                <ul class="text-sm text-blue-700 dark:text-blue-400 space-y-1">
                    <li>• Notlarınızı görevlerle ilişkilendirerek daha organize olun</li>
                    <li>• Açıklayıcı başlıklar kullanın, arama yaparken kolaylık sağlar</li>
                    <li>• Detaylı içerik ekleyerek notlarınızı daha faydalı hale getirin</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<script>
    // Character counter
    const contentTextarea = document.querySelector('textarea[name="Content"]');
    const charCountElement = document.getElementById('charCount');

    contentTextarea.addEventListener('input', function () {
        const count = this.value.length;
        charCountElement.textContent = count + ' karakter';
    });

    // Form validation
    document.querySelector('form').addEventListener('submit', function (e) {
        const title = document.querySelector('input[name="Title"]').value.trim();
        const content = document.querySelector('textarea[name="Content"]').value.trim();
        const userId = document.querySelector('select[name="UserId"]').value;

        if (!title || !content || !userId) {
            e.preventDefault();
            alert('Lütfen tüm zorunlu alanları doldurun!');
        }
    });
</script>
