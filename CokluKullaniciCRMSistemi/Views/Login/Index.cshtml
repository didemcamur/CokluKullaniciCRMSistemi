
@{
    Layout = null;
}

<!DOCTYPE html>

<html class="light" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>CRM Giriş Ekranı</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <script id="tailwind-config">
    tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#007BFF",
                        "background-light": "#F4F6F8",
                        "background-dark": "#0f1923",
                        "text-primary": "#333333",
                        "text-secondary": "#495057",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }</script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        input:focus {
            outline: 2px solid #007BFF !important;
            outline-offset: 2px !important;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-text-primary dark:text-white">
    <div class="relative flex min-h-screen w-full flex-col items-center justify-center bg-background-light dark:bg-background-dark group/design-root overflow-x-hidden p-4">
        <div class="layout-container flex h-full grow flex-col justify-center items-center w-full">
            <div class="w-full max-w-md bg-white dark:bg-background-dark rounded-xl shadow-lg p-8">
                <div class="flex flex-col items-center mb-6">
                    <svg class="h-12 w-12 text-primary mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                    <div class="text-center">
                        <p class="text-text-primary dark:text-white text-2xl font-black leading-tight tracking-tight">CRM Sistemine Hoş Geldiniz</p>
                        <p class="text-text-secondary dark:text-gray-300 text-base font-normal leading-normal mt-1">Lütfen giriş yapmak için bilgilerinizi girin.</p>
                    </div>
                </div>
                @using (Html.BeginForm("Index", "Login", FormMethod.Post))
                {
                    if (ViewBag.Hata != null)
                    {
                        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-4" role="alert">
                            <p class="font-medium">@ViewBag.Hata</p>
                        </div>
                    }
            <div class="flex flex-col gap-4">
                <label class="flex flex-col">
                    <p class="text-text-primary text-sm font-medium pb-2">Kullanıcı Adı / E-posta</p>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary">person</span>
                        <input class="form-input w-full rounded-lg border border-gray-300 bg-white h-12 pl-10 pr-4 py-2.5 text-base text-text-primary focus:outline-0 focus:ring-2 focus:ring-primary"
                               placeholder="Kullanıcı adınızı veya e-postanızı girin"
                               name="emailOrUsername" type="text" required />
                    </div>
                </label>

                <label class="flex flex-col">
                    <p class="text-text-primary dark:text-white text-sm font-medium leading-normal pb-2">Parola</p>
                    <div class="relative flex w-full flex-1 items-stretch rounded-lg">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary dark:text-gray-400">lock</span>
                        <input class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-text-primary dark:text-white focus:outline-0 focus:ring-0 border border-[#dae0e7] dark:border-gray-600 bg-white dark:bg-gray-700 h-12 placeholder:text-text-secondary dark:placeholder-gray-400 pl-10 pr-10 py-2.5 text-base font-normal leading-normal"
                               placeholder="Parolanızı girin"
                               name="sifre" type="password" value="" />
                        <button class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary dark:text-gray-400" type="button">
                            <span class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                </label>

                <div class="flex flex-wrap justify-between items-center gap-2">
                </div>

                <button class="flex min-w-[84px] w-full cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-5 bg-primary text-white text-base font-bold leading-normal tracking-[0.015em] hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary dark:focus:ring-offset-background-dark transition-colors duration-200"
                        type="submit">
                    <span class="truncate">Giriş Yap</span>
                </button>

            </div>
                }
            </div>
            <div class="text-center mt-8">
                <p class="text-text-secondary dark:text-gray-400 text-sm">© 2025 EİİBO - .Net Backend-Developer Eğitimi CRM Sistemi. Tüm hakları saklıdır.</p>
                <div class="flex justify-center gap-4 mt-2">
                    <a class="text-sm text-primary hover:underline" href="#">Destek</a>
                    <a class="text-sm text-primary hover:underline" href="#">Hakkında</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>